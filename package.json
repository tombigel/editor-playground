{
  "name": "editor-playground",
  "private": true,
  "version": "0.12.36",
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "postinstall": "simple-git-hooks",
    "version:minor": "node scripts/bump-version.mjs all minor",
    "version:major": "node scripts/bump-version.mjs all major",
    "sync:public": "node scripts/sync-public-assets.mjs",
    "build:nocheck": "vite build",
    "build:ds": "node scripts/sync-public-assets.mjs && vite build --config vite.design-system.config.ts",
    "dev": "vite",
    "lint": "biome lint ./src",
    "typecheck": "tsc -b",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test:coverage && pnpm run check:api-docs && pnpm run check:architecture && pnpm run test:e2e:smoke",
    "build": "pnpm run check && vite build",
    "deploy": "pnpm run build && node scripts/deploy-webdav.mjs",
    "refresh:google-fonts": "node scripts/refresh-google-fonts-catalog.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:a11y": "vitest run --config vitest.e2e.config.ts src/app/tests/axe.e2e.test.ts",
    "test:e2e:richtext": "vitest run --config vitest.richtext.e2e.config.ts",
    "test:e2e:smoke": "vitest run --config vitest.e2e.config.ts src/app/tests/smoke.e2e.test.ts",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:api-docs": "node scripts/check-api-docs.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@types/prismjs": "^1.26.6",
    "@wix/interact": "^2.2.1",
    "@wix/motion": "^2.1.7",
    "@wix/motion-presets": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "hdr-color-input": "^0.4.0",
    "lucide-react": "^1.7.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "slate": "^0.124.0",
    "slate-history": "^0.110.0",
    "slate-react": "^0.115.0",
    "tailwind-merge": "^3.5.0"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/pre-commit-version-bump.mjs",
    "commit-msg": "pnpm exec commitlint --edit $1",
    "post-commit": "node scripts/commit-msg-changelog.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "semver": "^7.7.2",
    "shadcn": "^4.1.2",
    "simple-git-hooks": "^2.13.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
