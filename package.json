{
  "name": "sticky-playground",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "biome lint ./src",
    "typecheck": "tsc -b",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run check:architecture",
    "build": "npm run check && vite build",
    "deploy": "npm run build && node scripts/deploy-webdav.mjs",
    "refresh:google-fonts": "node scripts/refresh-google-fonts-catalog.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "check:architecture": "sh -c 'rg -n -e \"from ../model\" -e \"from ../stage\" src/app src/panels && exit 1 || true; rg -n \"\\.\\./(editor|app|panels|stage|api)\" src/model src/sticky && exit 1 || true; rg -n \"\\.\\./(editor|api|app|panels|stage)\" src/site && exit 1 || true'"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "hdr-color-input": "^0.3.5",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "playwright": "^1.58.2",
    "shadcn": "^4.0.6",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
